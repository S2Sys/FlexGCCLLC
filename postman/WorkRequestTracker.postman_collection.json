          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.id) pm.collectionVariables.set('workRequestId', json.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman created request\",\n  \"clientName\": \"FlexGCCLLC\",\n  \"description\": \"Created from Postman collection.\",\n  \"priority\": \"Medium\",\n  \"status\": \"New\",\n  \"dueDate\": \"2026-05-30T00:00:00Z\"\n}"
        },
